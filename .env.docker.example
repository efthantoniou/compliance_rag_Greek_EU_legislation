# Copy to .env.docker and adjust paths for your machine.
# Host directory containing the GGUF model(s):
LLAMA_MODELS_DIR=<LLAMA MODEL PATH LOCATION>
# GGUF filename inside that directory:
LLAMACPP_MODEL_FILE=llama-krikri-8b-instruct-q8_0.gguf
# Host HuggingFace cache (reuses the already-downloaded embedding model + dataset):
HF_CACHE_DIR=<~/.cache/hugging-face>
# Optional: send agent traces to Logfire (leave unset for local console traces):
# LOGFIRE_TOKEN=
# Host user/group that owns ./data — SurrealDB runs as this uid so it can write
# the bind-mounted corpus. Defaults to 1000:1000; check with `id -u` / `id -g`.
HOST_UID=1000
HOST_GID=1000
# Cross-encoder reranker (downloads into the mounted HF cache on first use).
# Set RERANKER_DEVICE=cuda only if VRAM has headroom next to llama.cpp.
#RERANKER_MODEL=BAAI/bge-reranker-v2-m3
#RERANKER_DEVICE=cpu
# SurrealDB root credentials. Default to root/root if unset. Change BOTH before
# exposing the DB; the surrealdb, backend, and ingest services all read these.
# NOTE: the datastore in ./data is created with the credentials from its FIRST
# start — to change them on an existing corpus, re-ingest into a fresh ./data.
#SURREALDB_USER=root
#SURREALDB_PASS=root
